.technical-width {
  max-width: 860px;
}

.technical-hero {
  padding: 76px 0 72px;
  border-bottom: 1px solid var(--line);
  background: white;
}

.technical-hero .back {
  display: inline-block;
  margin-bottom: 56px;
  color: var(--ink-600);
  font-size: 0.78rem;
  font-weight: 700;
}

.technical-hero .back:hover {
  color: var(--teal);
}

.technical-hero h1 {
  max-width: 820px;
  margin: 0;
  font-family: var(--serif);
  font-size: clamp(3.2rem, 7vw, 6rem);
  font-weight: 500;
  letter-spacing: -0.05em;
  line-height: 0.95;
}

.technical-hero .description {
  max-width: 700px;
  margin: 28px 0 0;
  color: var(--ink-600);
  font-family: var(--serif);
  font-size: 1.25rem;
  line-height: 1.65;
}

.technical-hero .meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px 26px;
  margin-top: 32px;
  color: var(--ink-600);
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.technical-body {
  padding-top: 70px;
  padding-bottom: 110px;
}

.technical-body h2 {
  margin: 2.2em 0 0.7em;
  font-family: var(--serif);
  font-size: 2.1rem;
  font-weight: 500;
  letter-spacing: -0.025em;
  line-height: 1.2;
}

.technical-body > h2:first-child {
  margin-top: 0;
}

.technical-body p,
.technical-body li {
  color: var(--ink-800);
  font-family: var(--serif);
  font-size: 1.08rem;
  line-height: 1.85;
}

.technical-body strong {
  color: var(--ink-950);
}

.technical-body .lead {
  color: var(--ink-950);
  font-size: 1.35rem;
  line-height: 1.7;
}

.technical-body .status,
.technical-body .note {
  margin: 38px 0;
  padding: 22px 26px;
  border: 1px solid var(--line);
  border-left: 3px solid var(--teal);
  border-radius: 4px 12px 12px 4px;
  background: white;
}

.technical-body .status p,
.technical-body .note p {
  margin: 0;
  font-family: var(--sans);
  font-size: 0.9rem;
}

.finding-list {
  margin-top: 30px;
}

.finding {
  display: grid;
  grid-template-columns: 54px 1fr 40px;
  gap: 24px;
  align-items: start;
  padding: 38px 4px;
  border-bottom: 1px solid var(--line);
}

.finding:first-child {
  border-top: 1px solid var(--line);
}

.finding > span {
  color: var(--teal);
  font-family: var(--serif);
  font-size: 1.2rem;
}

.finding small {
  color: var(--ink-600);
  font-size: 0.68rem;
  font-weight: 750;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.finding h2 {
  margin: 8px 0;
  font-size: clamp(1.8rem, 4vw, 2.7rem);
}

.finding p {
  max-width: 680px;
  margin: 0;
  color: var(--ink-600);
  font-family: var(--sans);
  font-size: 1rem;
  line-height: 1.6;
}

.finding b {
  font-size: 1.7rem;
  transition: transform 160ms ease;
}

.finding:hover h2 {
  color: var(--teal);
}

.finding:hover b {
  transform: translateX(8px);
}

@media (max-width: 600px) {
  .technical-hero {
    padding: 64px 0 52px;
  }

  .technical-hero .back {
    margin-bottom: 40px;
  }

  .finding {
    grid-template-columns: 35px 1fr;
    gap: 15px;
  }

  .finding b {
    display: none;
  }
}

/* Rich technical-content primitives used by long-form explanatory pages. */
.technical-body h3 {
  margin: 2em 0 0.55em;
  font-family: var(--serif);
  font-size: 1.48rem;
  font-weight: 600;
  letter-spacing: -0.018em;
  line-height: 1.3;
}

.technical-body a {
  color: var(--teal);
  text-decoration: underline;
  text-decoration-color: rgba(22, 141, 128, 0.35);
  text-underline-offset: 0.18em;
}

.technical-body code {
  padding: 0.12em 0.3em;
  border-radius: 4px;
  background: rgba(16, 27, 54, 0.065);
  font-size: 0.86em;
}

.technical-body pre {
  overflow-x: auto;
  margin: 28px 0;
  padding: 22px 24px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--ink-950);
  box-shadow: 0 14px 36px rgba(16, 27, 54, 0.1);
}

.technical-body pre code {
  padding: 0;
  color: #e8eee9;
  background: none;
  font-size: 0.86rem;
  line-height: 1.7;
}

.technical-body table {
  width: 100%;
  margin: 30px 0 38px;
  border-collapse: collapse;
  font-size: 0.88rem;
}

.technical-body th,
.technical-body td {
  padding: 13px 14px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: top;
}

.technical-body th {
  color: var(--ink-950);
  background: rgba(96, 216, 192, 0.11);
  font-size: 0.72rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.technical-body td {
  color: var(--ink-800);
}

.resource-stack {
  display: grid;
  gap: 8px;
  margin: 32px 0;
  padding: 24px;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: white;
}

.resource-stack div {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  padding: 14px 18px;
  border-radius: 8px;
  background: var(--paper-deep);
}

.resource-stack span,
.resource-stack b {
  color: var(--ink-600);
  font-size: 0.78rem;
}

.resource-stack b {
  text-align: center;
}

.solver-loop {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 140px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  margin: 36px 0;
  padding: 26px;
  border: 1px solid var(--line);
  border-radius: 20px;
  background: white;
  box-shadow: 0 18px 48px rgba(16, 27, 54, 0.08);
}

.solver-block {
  display: flex;
  flex-direction: column;
  min-height: 150px;
  padding: 20px;
  border: 1px solid rgba(22, 141, 128, 0.24);
  border-radius: 13px;
  background: rgba(96, 216, 192, 0.12);
}

.solver-block--learned {
  border-color: rgba(242, 180, 109, 0.42);
  background: rgba(242, 180, 109, 0.16);
}

.solver-block > span {
  color: var(--teal);
  font-size: 0.64rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.solver-block--learned > span {
  color: #a56324;
}

.solver-block strong {
  margin-top: auto;
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.2;
}

.solver-block small {
  margin-top: 9px;
  color: var(--ink-600);
  font-size: 0.68rem;
  line-height: 1.45;
}

.solver-loop__arrows {
  position: relative;
  height: 84px;
}

.solver-loop__arrows > span {
  position: absolute;
  inset: 50% auto auto 50%;
  color: var(--ink-400);
  font-size: 0.58rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  transform: translate(-50%, -50%);
}

.solver-loop__arrows svg {
  width: 100%;
  height: 100%;
  overflow: visible;
}

.solver-loop__arrows path {
  fill: none;
  stroke: var(--teal);
  stroke-width: 2;
  stroke-linecap: round;
}

.solver-loop__arrows .solver-loop__back {
  stroke: var(--apricot);
}

#article-arrow-physics path {
  fill: var(--teal);
  stroke: none;
}

#article-arrow-learning path {
  fill: var(--apricot);
  stroke: none;
}

.split-card__copy {
  color: var(--ink-800);
  font-family: var(--sans);
  font-size: 0.92rem;
  line-height: 1.55;
}

@media (max-width: 680px) {
  .solver-loop {
    grid-template-columns: 1fr;
  }

  .solver-loop__arrows {
    width: 140px;
    margin: 4px auto;
    transform: rotate(90deg);
  }
}

.split-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  margin: 32px 0;
}

.split-card {
  display: grid;
  gap: 9px;
  padding: 24px;
  border: 1px solid rgba(22, 141, 128, 0.22);
  border-radius: 14px;
  background: rgba(96, 216, 192, 0.1);
}

.split-card--warm {
  border-color: rgba(242, 180, 109, 0.35);
  background: rgba(242, 180, 109, 0.13);
}

.split-card__tag,
.flow-diagram small,
.iteration-strip small {
  color: var(--ink-600);
  font-size: 0.66rem;
  font-weight: 750;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.split-card p,
.split-card small {
  margin: 0;
  font-family: var(--sans);
}

.split-card p {
  font-size: 0.92rem;
  line-height: 1.55;
}

.split-card small {
  color: var(--ink-600);
}

.flow-diagram,
.iteration-strip {
  display: flex;
  align-items: center;
  gap: 12px;
  overflow-x: auto;
  margin: 32px 0;
  padding: 24px;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: white;
}

.flow-node,
.flow-workers div,
.iteration-strip > span {
  display: grid;
  gap: 4px;
  min-width: max-content;
  padding: 13px 15px;
  border-radius: 8px;
  background: var(--paper-deep);
  text-align: center;
}

.flow-node--input,
.iteration-strip__physics {
  background: rgba(96, 216, 192, 0.16) !important;
}

.flow-workers {
  display: grid;
  gap: 6px;
}

.flow-workers div {
  grid-template-columns: 52px 1fr;
  text-align: left;
}

.flow-arrow,
.iteration-strip > b {
  color: var(--teal);
}

.iteration-strip > span {
  min-width: 105px;
}

.iteration-strip__prior {
  background: rgba(242, 180, 109, 0.2) !important;
}

.tiling-figure {
  margin: 38px 0;
  padding: 22px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: white;
  box-shadow: 0 16px 42px rgba(16, 27, 54, 0.08);
}

.tiling-flow {
  display: grid;
  grid-template-columns:
    minmax(110px, 1fr) 18px minmax(110px, 1fr) 18px
    minmax(110px, 1fr) 18px minmax(110px, 1fr) 18px minmax(110px, 1fr);
  gap: 8px;
  align-items: center;
}

.tiling-stage {
  display: grid;
  grid-template-rows: auto minmax(2.5em, auto) 104px;
  gap: 7px;
  min-width: 0;
  padding: 12px 10px;
  border: 1px solid rgba(16, 27, 54, 0.1);
  border-radius: 12px;
  background: var(--paper-deep);
  text-align: center;
}

.tiling-stage--workers {
  border-color: rgba(242, 180, 109, 0.38);
  background: rgba(242, 180, 109, 0.12);
}

.tiling-stage__step {
  color: var(--teal);
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.tiling-stage strong {
  display: flex;
  align-items: start;
  justify-content: center;
  font-family: var(--serif);
  font-size: 0.92rem;
  line-height: 1.2;
}

.tiling-canvas,
.tiling-stack,
.tiling-workers {
  width: min(100%, 112px);
  height: 92px;
  margin: auto;
}

.tiling-canvas {
  position: relative;
  overflow: hidden;
  border: 2px solid rgba(16, 27, 54, 0.18);
  border-radius: 9px;
  background-color: #e9f5f1;
  background-image:
    linear-gradient(to right, rgba(16, 27, 54, 0.11) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(16, 27, 54, 0.11) 1px, transparent 1px),
    linear-gradient(135deg, rgba(96, 216, 192, 0.24), rgba(242, 180, 109, 0.2));
  background-size:
    18px 18px,
    18px 18px,
    100% 100%;
}

.tiling-canvas--output {
  border-color: rgba(22, 141, 128, 0.45);
  background-image:
    linear-gradient(to right, rgba(16, 27, 54, 0.055) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(16, 27, 54, 0.055) 1px, transparent 1px),
    linear-gradient(135deg, rgba(96, 216, 192, 0.32), rgba(242, 180, 109, 0.25));
}

.tiling-stack {
  position: relative;
}

.tiling-patch {
  position: absolute;
  width: 68%;
  height: 68%;
  border: 2px dashed currentColor;
  border-radius: 7px;
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 4px 10px rgba(16, 27, 54, 0.1);
}

.tiling-patch::after {
  position: absolute;
  inset: 8px;
  border: 2px solid currentColor;
  border-radius: 3px;
  content: "";
}

.tiling-patch--one {
  top: 0;
  left: 0;
  color: #168d80;
}

.tiling-patch--two {
  top: 0;
  right: 0;
  color: #3478b8;
}

.tiling-patch--three {
  bottom: 0;
  left: 0;
  color: #d18a38;
}

.tiling-patch--four {
  right: 0;
  bottom: 0;
  color: #a45d73;
}

.tiling-workers {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
}

.tiling-workers > span {
  display: grid;
  place-content: center;
  border: 1px solid rgba(16, 27, 54, 0.13);
  border-top: 3px solid var(--teal);
  border-radius: 7px;
  background: white;
}

.tiling-workers > span:nth-child(2) {
  border-top-color: #3478b8;
}

.tiling-workers > span:nth-child(3) {
  border-top-color: #d18a38;
}

.tiling-workers > span:nth-child(4) {
  border-top-color: #a45d73;
}

.tiling-workers b {
  color: var(--ink-950);
  font-family: var(--serif);
  font-size: 0.85rem;
}

.tiling-workers small {
  color: var(--ink-600);
  font-size: 0.52rem;
  line-height: 1.2;
}

.tiling-blend {
  position: absolute;
  z-index: 1;
  display: block;
  pointer-events: none;
}

.tiling-blend--x {
  inset: 0 auto 0 50%;
  width: 24px;
  transform: translateX(-50%);
  background: linear-gradient(
    to right,
    transparent,
    rgba(255, 255, 255, 0.9),
    transparent
  );
}

.tiling-blend--y {
  inset: 50% 0 auto;
  height: 24px;
  transform: translateY(-50%);
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(255, 255, 255, 0.9),
    transparent
  );
}

.tiling-arrow {
  color: var(--teal);
  font-size: 1.35rem;
  font-weight: 700;
  text-align: center;
}

.tiling-figure figcaption {
  max-width: 680px;
  margin: 18px auto 0;
  color: var(--ink-600);
  font-family: var(--sans);
  font-size: 0.76rem;
  line-height: 1.55;
  text-align: center;
}

.technical-body .katex-display {
  display: block;
  overflow-x: auto;
  overflow-y: hidden;
  margin: 1.5rem 0;
  padding: 0.4rem 0;
}

.technical-body code.math-inline,
.technical-body code.math-display {
  padding: 0;
  color: inherit;
  background: none;
  font-size: inherit;
}

@media (max-width: 760px) {
  .tiling-flow {
    grid-template-columns: minmax(0, 260px);
    justify-content: center;
  }

  .tiling-stage {
    width: 100%;
  }

  .tiling-arrow {
    height: 22px;
    transform: rotate(90deg);
  }
}

@media (max-width: 600px) {
  .technical-body table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
  }

  .resource-stack div {
    display: grid;
    gap: 3px;
  }

  .split-grid {
    grid-template-columns: 1fr;
  }

  .tiling-figure {
    padding: 16px;
  }
}

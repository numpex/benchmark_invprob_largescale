---
import "../styles/components/footer.css";
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a
        href="https://numpex.org/"
        target="_blank"
        rel="noreferrer"
        aria-label="Visit the NumPEx website"
      >
        <img src={`${base}logo_numpex.png`} alt="NumPEx" />
      </a>
      <p class="footer-title">Inverse Problems <span>at scale</span></p>
    </div>
    <div class="footer-links">
      <a href={`${base}documentation/`}>Documentation</a>
      <a
        class="github-link"
        href="https://github.com/numpex/benchmark_invprob_largescale"
        target="_blank"
        rel="noreferrer"
        aria-label="View the benchmark source code on GitHub"
      >
        <img src={`${base}github.png`} alt="" />
        <span>GitHub</span>
      </a>
    </div>
  </div>
</footer>
